{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.4.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "hr",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*.hr-nekretnine.hr/*",
    "*://hr-nekretnine.hr/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.hr-nekretnine.hr/*",
        "*://hr-nekretnine.hr/*"
      ],
      "css": ["content/content.css"],
      "js": ["content/content.js"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png",
      "256": "icons/icon256.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  }
}
